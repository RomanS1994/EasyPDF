# Frontend-only Vite environment variables.
# Do not put backend secrets, API secrets, or database credentials here.

VITE_API_BASE_URL=http://localhost:3001/api

# Optional public client header key. Must match backend API_KEY if enabled.
VITE_API_KEY=

# Optional public support links shown for manual payment confirmation.
VITE_SUPPORT_WHATSAPP_URL=
VITE_SUPPORT_TELEGRAM_URL=
