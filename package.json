{
  "name": "pdf-app",
  "private": true,
  "version": "1.0.0",
  "description": "PDF app with frontend contract generator and local backend for auth, plans, and orders",
  "type": "module",
  "scripts": {
    "dev": "node tools/dev.js",
    "dev:client": "vite",
    "dev:server": "npm --prefix backend run dev",
    "db:generate": "npm --prefix backend run db:generate",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:migrate:deploy": "npm --prefix backend run db:migrate:deploy",
    "db:migrate-json": "npm --prefix backend run db:migrate-json --",
    "admin:create": "npm --prefix backend run admin:create --",
    "hooks:install": "node tools/install-git-hooks.js",
    "prepare": "node tools/install-git-hooks.js",
    "secrets:check": "node tools/check-secrets.js",
    "build": "vite build --base=/",
    "preview": "vite preview",
    "start:server": "npm --prefix backend run start"
  },
  "devDependencies": {
    "postcss": "^8.4.41",
    "postcss-sort-media-queries": "^5.2.0",
    "vite": "^5.4.6"
  },
  "author": "Roman Stryzhka rstrizhko1994@gmail.com",
  "license": "ISC",
  "dependencies": {
    "flatpickr": "^4.6.13",
    "toastify-js": "^1.12.0",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-plugin-html-inject": "^1.1.2"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
